# ─── Server ───────────────────────────────────────────────────────────────
PORT=4000

# Postgres connection string (Neon / Supabase / local). Example for local:
# postgresql://postgres:postgres@localhost:5432/mentorque
DATABASE_URL=""

# Secret used to sign auth JWTs and per-interview tokens. Use a long random string.
JWT_SECRET=""

# Gemini API key — powers the LangGraph interview engine + feedback report.
# Free key (no card required): https://aistudio.google.com/apikey
GEMINI_API_KEY=""

# Optional model-tier overrides (defaults shown).
# The turn model both speaks and scores answers in one merged call.
# GEMINI_TURN_MODEL="gemini-2.5-flash"
# GEMINI_REPORT_MODEL="gemini-3.5-flash"

# Public URL of THIS server, reachable by Vapi's cloud (the custom-LLM webhook
# target). Locally, run `ngrok http 4000` and paste the https URL here.
# In production, this is your deployed API URL.
PUBLIC_SERVER_URL="https://your-server.ngrok-free.app"

# Vapi private key — only needed if you later create persistent assistants
# server-side. The current transient-assistant flow does not require it.
VAPI_PRIVATE_KEY=""

# ─── Client (Vite — must be prefixed with VITE_) ────────────────────────────
# Vapi PUBLIC key (safe to expose in the browser). From your Vapi dashboard.
VITE_VAPI_PUBLIC_KEY="your-vapi-public-key"

# Where the browser reaches the API. Local dev default:
VITE_API_URL="http://localhost:4000"
